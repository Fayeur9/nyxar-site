# -------------------------------------------------------
# VITE_SITE_URL — REQUIS pour le build de production
# -------------------------------------------------------
# Utilisée dans index.html pour les balises Open Graph (og:image, og:url, twitter:image).
# Sans cette variable, les aperçus de liens (Discord, Twitter, etc.) seront cassés.
# Ne pas mettre de slash final.
# En dev : inutile, ne pas créer de .env frontend.
# En prod : créer frontend/.env avec cette valeur avant de lancer npm run build.
VITE_SITE_URL=https://nyxar.fr

# -------------------------------------------------------
# VITE_API_URL — optionnel
# -------------------------------------------------------
# L'URL de l'API est auto-détectée (même domaine en prod, localhost:5176 en dev).
# Décommenter uniquement si l'API tourne sur un domaine séparé.
# VITE_API_URL=https://api.nyxar.fr
