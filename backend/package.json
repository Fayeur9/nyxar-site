{
  "name": "site_nyxar_backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Backend API for site_nyxar",
  "main": "server.js",
  "scripts": {
    "dev": "cross-env RESET_DB=true node --watch server.js",
    "dev:keep": "node --watch server.js",
    "start": "node server.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs --coverage --coverageReporters=text --coverageReporters=html"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "audio-decode": "^2.2.3",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-fileupload": "^1.5.0",
    "express-rate-limit": "^8.3.0",
    "jsonwebtoken": "^9.0.0",
    "mysql2": "^3.16.0",
    "pg": "^8.11.3",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2"
  }
}
