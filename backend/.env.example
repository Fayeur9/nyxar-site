# Base de données MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=nyxar_db
DB_USER=root
DB_PASSWORD=your_mysql_password

# Authentification
JWT_SECRET=your_jwt_secret_key_here_min_32_chars

# Serveur
PORT=5176
NODE_ENV=development
# Origines CORS autorisées en production (séparées par des virgules)
# ALLOWED_ORIGINS=https://nyxar.fr,https://www.nyxar.fr

# Seed (optionnel — mots de passe utilisés par `npm run db:seed`)
# SEED_ADMIN_PASSWORD=admin25
# SEED_NYXAR_PASSWORD=nyxar25
# SEED_USER_PASSWORD=user25
